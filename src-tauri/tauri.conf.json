{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BadgeBadger Print Agent",
  "version": "0.1.0",
  "identifier": "com.badgebadger.printagent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BadgeBadger Print Agent",
        "width": 540,
        "height": 640,
        "minWidth": 420,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "category": "Utility",
    "shortDescription": "Local print agent for BadgeBadger",
    "longDescription": "Listens for print jobs from the BadgeBadger web app and dispatches them silently to your local printer. Ships SumatraPDF (GPLv3) as a bundled helper so single-MSI installs work without a separate PDF reader."
  }
}
